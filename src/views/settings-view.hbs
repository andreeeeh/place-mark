{{> menu active="settings"}}

<section class="section">
  <div class="card has-background-grey-lighter">
    <div class="card-content">
      <h2 class="title">Users</h2>
      <table class="table is-fullwidth is-striped is-hoverable">
        <thead>
          <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Admin</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each users}}
            <tr>
              <td>{{firstName}}</td>
              <td>{{lastName}}</td>
              <td>{{email}}</td>
              <td>
                <a 
                  id="admin-button" 
                  href="/settings/user/{{_id}}/admin" 
                  class="button is-small is-success is-light {{#if isAdmin}}is-success{{else}}is-danger{{/if}}">
                    {{#if isAdmin}}Yes{{else}}No{{/if}}
                  </a>
              </td>
              <td>
                <a href="/settings/user/{{_id}}/delete" class="button is-small is-danger is-light">Delete</a>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</section>


